# Copy to .env and fill in. All keys are prefixed OT_ (Option Terminal).
# In production, set OT_CREDENTIALS_ENCRYPTED=true and store ciphertext here,
# with OT_ENCRYPTION_KEY supplied via a secrets manager / systemd credential.

OT_API_KEY=your_smartapi_key
OT_CLIENT_CODE=your_client_code
OT_PIN=your_pin
OT_TOTP_SECRET=your_base32_totp_secret

OT_CREDENTIALS_ENCRYPTED=false
# OT_ENCRYPTION_KEY=generate_with__python -m utils.crypto keygen

# Database
OT_DB_BACKEND=sqlite
OT_DB_PATH=data/option_terminal.db

# Collection
OT_INDICES=NIFTY
OT_STRIKES_AROUND_ATM=15

# Logging
OT_LOG_LEVEL=INFO

# Alerts / Telegram (Phase 4) — optional
# OT_TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# OT_TELEGRAM_CHAT_ID=your_chat_or_channel_id
OT_ALERT_MIN_PRIORITY=MEDIUM
OT_ALERT_COOLDOWN_SEC=180

# Pricing model (Phase 5) — Black-76 assumptions
OT_RISK_FREE_RATE=0.065
OT_DIVIDEND_YIELD=0.012
